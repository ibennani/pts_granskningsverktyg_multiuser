# Kopiera till .env och anpassa vid behov
# cp .env.example .env

# Databas (PostgreSQL i Docker)
DATABASE_URL=postgresql://granskning:granskning@localhost:5432/granskningsverktyget

# Backend API
API_PORT=3000

# CORS (tillåtna origins, separera flera med kommatecken)
ALLOWED_ORIGINS=http://localhost:5173
# Backup (sökväg till mapp för granskningsbackuper, default: ./backup)
# GV_BACKUP_DIR=./backup

# JWT för inloggning (använd en stark hemlig nyckel i produktion)
JWT_SECRET=change-me-in-production

# Ngrok-URL för dev (npm run ngrok)
NGROK_URL=din-url-här


# Access-token TTL (jsonwebtoken expiresIn)
JWT_EXPIRES_IN=1h


LOG_LEVEL=info

