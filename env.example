# Kopiera till .env och anpassa vid behov
# cp env.example .env

# Databas (PostgreSQL i Docker)
DATABASE_URL=postgresql://granskning:granskning@localhost:5432/granskningsverktyget

# Backend API
API_PORT=3000

# SSH för deploy (valfritt – automatisk inloggning vid npm run deploy:v2)
# Fungerar på Windows, Linux och Mac (använder node-ssh)
# DEPLOY_SSH_PASSWORD=ditt_ssh_lösenord
# DEPLOY_USER=användarnamn  # Valfritt, standard: Windows-användarnamn eller granskning
# DEPLOY_SUDO_PASSWORD=lösenord  # För Nginx-uppdatering vid deploy (sudo på servern)
# DEPLOY_NGINX_CONF=/etc/nginx/conf.d/ux-granskning.conf  # Sökväg till Nginx-config på servern