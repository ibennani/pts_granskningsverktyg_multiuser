{
  "name": "modulbaserad-kod-v02",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n \"DOCKER,NGROK,APP\" -c \"blue,green,magenta\" \"node scripts/dev-with-docker.js\" \"npm run ngrok\" \"vite\"",
    "ngrok": "taskkill /f /im ngrok.exe 2>nul & ngrok http --url=irreproachable-eun-refractorily.ngrok-free.dev 11434",
    "vibe": "npm run dev",
    "dev:client": "vite",
    "dev:db": "docker compose -p sessionversion up -d --wait",
    "dev:stop": "docker compose -p sessionversion stop",
    "db:status": "node scripts/db-status.js",
    "dev:server": "node server/index.js",
    "db:migrate": "node server/scripts/migrate.js",
    "db:dedupe": "node server/scripts/dedupe-rules.js",
    "deploy:v2": "node scripts/deploy-v2.js",
    "build": "vite build && node scripts/postbuild-copy.js",
    "preview": "vite preview",
    "lint": "eslint . --max-warnings=0",
    "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --config jest.config.js --passWithNoTests"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.37.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.11",
    "prettier": "^3.6.2",
    "vite": "^7.1.7",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "@fontsource/roboto": "^5.2.10",
    "docx": "^9.6.0",
    "dotenv": "^16.6.1",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "marked": "^16.3.0",
    "node-ssh": "^13.2.1",
    "pg": "^8.18.0",
    "ws": "^8.19.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
