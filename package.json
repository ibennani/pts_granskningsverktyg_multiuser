{
  "name": "modulbaserad-kod-v02",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n \"DOCKER,NGROK,APP,BUILDINFO\" -c \"blue,green,magenta,cyan\" \"node scripts/dev-with-docker.js\" \"npm run ngrok\" \"npx wait-on tcp:localhost:3000 --timeout 60000 && cross-env BROWSER=msedge vite\" \"node scripts/dev-build-info-watcher.js\"",
    "dev:local": "npm run dev",
    "dev:serverdb": "node scripts/dev-server-db.js",
    "ngrok": "node scripts/ngrok.js",
    "vibe": "npm run dev",
    "dev:client": "vite",
    "dev:fixedport": "vite --port 5173 --strictPort",
    "dev:db": "docker compose -p sessionversion up -d --wait",
    "dev:stop": "docker compose -p sessionversion stop",
    "db:status": "node scripts/db-status.js",
    "dev:server": "tsx server/index.js",
    "db:migrate": "node server/scripts/migrate.js",
    "db:backup:remote": "node scripts/db-backup-remote.js",
    "db:backup:list:remote": "node scripts/db-backup-list-remote.js",
    "db:backup:verify:remote": "node scripts/db-backup-verify-remote.js",
    "cleanup:docker:remote": "node scripts/cleanup-docker-remote.js",
    "db:dedupe": "node server/scripts/dedupe-rules.js",
    "deploy:v2": "node scripts/deploy-v2.js",
    "deploy:v2:keep-build-info": "cross-env DEPLOY_KEEP_BUILD_INFO=1 node scripts/deploy-v2.js",
    "diagnose:v2": "node scripts/diagnose-v2-remote.js",
    "start:v2:remote": "node scripts/remote-start-v2-pm2.js",
    "remote:fix-prod-deps": "node scripts/remote-fix-prod-deps.js",
    "uppdatera:byggstämpel": "node scripts/update_public_build_info.js",
    "build": "vite build && node scripts/postbuild-copy.js",
    "preview": "vite preview",
    "lint:js": "eslint \"js/**/*.js\" \"shared/**/*.js\" --quiet",
    "lint:ts": "eslint \"js/**/*.ts\" --quiet",
    "lint": "npm run lint:js",
    "typecheck": "tsc --noEmit",
    "check:export-facades": "node scripts/check-export-facades.mjs",
    "check:js-ts-imports": "node scripts/verify_js_only_imports.mjs",
    "check:audit-logic-strict": "node scripts/verify_audit_logic_no_ts_nocheck.mjs",
    "fix:js-ts-bridges": "node scripts/verify_js_only_imports.mjs --fix",
    "extract:html-export": "node scripts/extract_html_export.cjs",
    "check": "npm run lint && npm run check:export-facades && npm run check:js-ts-imports && npm run check:audit-logic-strict && npm run typecheck && npm test",
    "check:full": "npm run lint:js && npm run lint:ts && npm run check:export-facades && npm run check:js-ts-imports && npm run check:audit-logic-strict && npm run typecheck && npm test && npm run build",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test --project=Chromium",
    "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --config jest.config.js --passWithNoTests"
  },
  "devDependencies": {
    "@ngrok/ngrok": "^1.7.0",
    "@playwright/test": "^1.56.0",
    "@swc/core": "^1.15.21",
    "@swc/jest": "^0.2.39",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/express": "^4.17.21",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "eslint": "^9.37.0",
    "eslint-plugin-import": "^2.32.0",
    "jest": "^29.7.0",
    "jest-axe": "^10.0.0",
    "jest-environment-jsdom": "^30.2.0",
    "node-ssh": "^13.2.1",
    "nodemon": "^3.1.11",
    "prettier": "^3.6.2",
    "typescript": "^6.0.2",
    "vite": "^7.1.7",
    "vite-plugin-pwa": "^1.2.0",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "@fontsource/roboto": "^5.2.10",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "docx": "^9.6.0",
    "dotenv": "^16.6.1",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "marked": "^18.0.4",
    "node-cron": "^4.2.1",
    "pg": "^8.18.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.21.0",
    "ws": "^8.19.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
