// Jest Snapshot v1, https://goo.gl/fbAQLP

exports[`AuditOverviewComponent snapshot renderar översikt med rubrik, progress och bristindex 1`] = `
"<div class="content-plate audit-overview-plate"><h1>Granskningsöversikt</h1><div class="overview-dashboard"><div class="dashboard-panel" id="audit-info-component-container"><div class="audit-info-panel"><div class="panel-header-wrapper"><h2 class="dashboard-panel__title" id="audit-info-heading">Granskningsinformation</h2></div><div class="info-item"><strong>Mål / ID</strong><p class="value">SNAP-1</p></div><div class="info-item"><strong>Aktör</strong><p class="value">Snap Aktör</p></div><div class="info-item"><strong>Granskare</strong><p class="value">Snap Granskare</p></div><div class="info-item"><strong>Regelfil</strong><p class="value">Minimal test rule file</p></div><div class="info-item"><strong>Version</strong><p class="value text-muted">---</p></div><div class="info-item"><strong>Status</strong><p class="value">Låst</p></div><div class="info-item"><strong>Start</strong><p class="value text-muted">---</p></div><div class="info-item"><strong>Senast uppdaterad</strong><p class="value text-muted">---</p></div></div></div><div class="dashboard-panel score-panel"><h2 class="dashboard-panel__title">Resultat och bristindex</h2><h3 class="dashboard-panel__subtitle" id="audit-overview-progress-heading">Klart hittills</h3><div class="info-item--progress-container"><p class="progress-text-wrapper audit-overview-progress-summary" id="audit-overview-progress-summary"><strong>Klart hittills: </strong><span class="value">0 / 1 kontroller (0,0 %)</span></p><div class="audit-status-stack progress-bar-wrapper audit-status-stack--overview"><div class="audit-status-stack__track" aria-hidden="true"><div class="audit-status-stack__segment audit-status-stack__segment--not_audited" style="flex-grow: 0; flex-shrink: 1; flex-basis: 100%; min-width: 0; box-sizing: border-box;"></div></div><h3 class="audit-status-stack__distribution-title" id="audit-overview-distribution-heading">Fördelning av kontroller</h3><ul class="audit-status-stack__distribution-list" aria-labelledby="audit-overview-distribution-heading"><li class="audit-status-stack__distribution-item"><span class="audit-status-stack__distribution-icon" aria-hidden="true"><span class="status-icon status-icon-failed">✗</span></span><span class="audit-status-stack__distribution-text"><span class="audit-status-stack__distribution-label">Underkänt: </span>0 st. (0,0 %)</span></li><li class="audit-status-stack__distribution-item"><span class="audit-status-stack__distribution-icon" aria-hidden="true"><span class="status-icon status-icon-passed">✓</span></span><span class="audit-status-stack__distribution-text"><span class="audit-status-stack__distribution-label">Ingen anmärkning: </span>0 st. (0,0 %)</span></li><li class="audit-status-stack__distribution-item"><span class="audit-status-stack__distribution-icon" aria-hidden="true"><span class="status-icon status-icon-partially-audited">◐</span></span><span class="audit-status-stack__distribution-text"><span class="audit-status-stack__distribution-label">Delvis granskad: </span>0 st. (0,0 %)</span></li><li class="audit-status-stack__distribution-item"><span class="audit-status-stack__distribution-icon" aria-hidden="true"><span class="status-icon status-icon-not-audited">○</span></span><span class="audit-status-stack__distribution-text"><span class="audit-status-stack__distribution-label">Återstår: </span>1 st. (100,0 %)</span></li></ul></div></div><div style="border-bottom: 1px dashed var(--secondary-color); margin: 1.5rem 0px;"></div><div id="score-analysis-component-container"><div class="score-analysis-content"><div class="score-analysis-total"><h3 class="score-analysis-total__title">Bristindex</h3><span class="visually-hidden">Bristindex: 0,0</span><div class="score-analysis-total__visualization"><div class="score-gauge-wrapper">
            <svg viewBox="0 0 100 85" class="score-gauge-svg" aria-hidden="true">
                <!-- Gauge track (background) -->
                <path class="score-gauge__track" d="M 78.2842712474619 78.2842712474619 A 40 40 0 1 0 21.71572875253809 78.2842712474619"></path>
                
                <!-- Gauge segments with straight boundaries -->
                <path d="M 10.123306650674884 53.13836382911379 A 40 40 0 0 0 21.71572875253809 78.2842712474619" stroke="var(--gradient-success-color)" stroke-width="10" stroke-linecap="butt" fill="none"></path>
                <path d="M 17.63932022500211 26.48858990830107 A 40 40 0 0 0 10.123306650674884 53.13836382911379" stroke="var(--gradient-warning-color)" stroke-width="10" stroke-linecap="butt" fill="none"></path>
                <path d="M 40.6621854457638 11.105203184092936 A 40 40 0 0 0 17.63932022500211 26.48858990830107" stroke="var(--gradient-orange-color)" stroke-width="10" stroke-linecap="butt" fill="none"></path>
                <path d="M 78.2842712474619 78.2842712474619 A 40 40 0 0 0 40.6621854457638 11.105203184092936" stroke="var(--gradient-danger-color)" stroke-width="10" stroke-linecap="butt" fill="none"></path>
                
                <!-- Value text -->
                <text x="50" y="55" class="score-gauge__value">0,0</text>

                <!-- Marker -->
                <g class="score-gauge__marker-group" transform="rotate(-135 50 50)">
                    <circle class="score-gauge__marker" cx="50" cy="10" r="4"></circle>
                </g>
            </svg>
        </div><div class="score-analysis-total__context"><p class="score-analysis-total__subtext">(Lägre är bättre)</p><p class="score-analysis-total__info">Baserat på stickprov</p></div></div></div><div class="score-analysis-principles"><h3 class="score-analysis-principles__title">Per princip</h3><ul class="score-analysis-principles__list"><li class="principle-row"><div class="principle-row__name">Upplevbar</div><div class="principle-row__bar-container"><div class="principle-row__bar" style="width: 0%; --score-percent: 0;" aria-hidden="true"></div><span class="principle-row__value">0,0</span></div></li><li class="principle-row"><div class="principle-row__name">Hanterbar</div><div class="principle-row__bar-container"><div class="principle-row__bar" style="width: 0%; --score-percent: 0;" aria-hidden="true"></div><span class="principle-row__value">0,0</span></div></li><li class="principle-row"><div class="principle-row__name">Begriplig</div><div class="principle-row__bar-container"><div class="principle-row__bar" style="width: 0%; --score-percent: 0;" aria-hidden="true"></div><span class="principle-row__value">0,0</span></div></li><li class="principle-row"><div class="principle-row__name">Robust</div><div class="principle-row__bar-container"><div class="principle-row__bar" style="width: 0%; --score-percent: 0;" aria-hidden="true"></div><span class="principle-row__value">0,0</span></div></li></ul></div></div></div><div class="audit-overview-sampletype-chart-wrap" id="audit-sampletype-chart-root"></div></div></div></div>"
`;
