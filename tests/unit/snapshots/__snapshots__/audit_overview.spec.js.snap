// Jest Snapshot v1, https://goo.gl/fbAQLP

exports[`AuditOverviewComponent snapshot renderar översikt med rubrik, progress och bristindex 1`] = `
"<div class="content-plate audit-overview-plate"><div class="global-msg-mock"></div><h1>Granskningsöversikt</h1><div class="overview-dashboard"><div class="dashboard-panel" id="audit-info-component-container"><div class="audit-info-panel"><div class="panel-header-wrapper"><h2 class="dashboard-panel__title" id="audit-info-heading">Granskningsinformation</h2></div><div class="info-item"><strong>Mål / ID</strong><p class="value">SNAP-1</p></div><div class="info-item"><strong>Aktör</strong><p class="value">Snap Aktör</p></div><div class="info-item"><strong>Granskare</strong><p class="value">Snap Granskare</p></div><div class="info-item"><strong>Regelfil</strong><p class="value">Minimal test rule file</p></div><div class="info-item"><strong>Version</strong><p class="value text-muted">---</p></div><div class="info-item"><strong>Status</strong><p class="value">Låst</p></div><div class="info-item"><strong>Start</strong><p class="value text-muted">---</p></div><div class="info-item"><strong>Slut</strong><p class="value">---</p></div></div></div><div class="dashboard-panel score-panel"><h2 class="dashboard-panel__title">Resultat och bristindex</h2><h3 class="dashboard-panel__subtitle">Klart hittills</h3><div class="info-item--progress-container"><p class="progress-text-wrapper"><strong>Granskade krav:</strong><span class="value">0 / 1 (0,0 %)</span></p><div class="progress-bar-wrapper"><progress class="progress-bar-element" value="0" max="1" aria-label="progress_bar_label" aria-valuemin="0" aria-valuemax="1" aria-valuenow="0" aria-hidden="true"></progress></div></div><div style="border-bottom: 1px dashed var(--secondary-color); margin: 1.5rem 0px;"></div><div id="score-analysis-component-container"><div class="score-analysis-content"><div class="score-analysis-total"><h3 class="score-analysis-total__title">Bristindex</h3><span class="visually-hidden">Bristindex: 10,0</span><div class="score-analysis-total__visualization"><div class="score-gauge-wrapper">
            <svg viewBox="0 0 100 85" class="score-gauge-svg" aria-hidden="true">
                <!-- Gauge track (background) -->
                <path class="score-gauge__track" d="M 78.2842712474619 78.2842712474619 A 40 40 0 1 0 21.71572875253809 78.2842712474619"></path>
                
                <!-- Gauge segments with straight boundaries -->
                <path d="M 10.123306650674884 53.13836382911379 A 40 40 0 0 0 21.71572875253809 78.2842712474619" stroke="var(--gradient-success-color)" stroke-width="10" stroke-linecap="butt" fill="none"></path>
                <path d="M 17.63932022500211 26.48858990830107 A 40 40 0 0 0 10.123306650674884 53.13836382911379" stroke="var(--gradient-warning-color)" stroke-width="10" stroke-linecap="butt" fill="none"></path>
                <path d="M 40.6621854457638 11.105203184092936 A 40 40 0 0 0 17.63932022500211 26.48858990830107" stroke="var(--gradient-orange-color)" stroke-width="10" stroke-linecap="butt" fill="none"></path>
                <path d="M 78.2842712474619 78.2842712474619 A 40 40 0 0 0 40.6621854457638 11.105203184092936" stroke="var(--gradient-danger-color)" stroke-width="10" stroke-linecap="butt" fill="none"></path>
                
                <!-- Value text -->
                <text x="50" y="55" class="score-gauge__value">10,0</text>

                <!-- Marker -->
                <g class="score-gauge__marker-group" transform="rotate(-108 50 50)">
                    <circle class="score-gauge__marker" cx="50" cy="10" r="4"></circle>
                </g>
            </svg>
        </div><div class="score-analysis-total__context"><p class="score-analysis-total__subtext">(Lägre är bättre)</p><p class="score-analysis-total__info">Baserat på stickprov</p></div></div></div><div class="score-analysis-principles"><h3 class="score-analysis-principles__title">Per princip</h3><ul class="score-analysis-principles__list"><li class="principle-row"><div class="principle-row__name">Upplevbar</div><div class="principle-row__bar-container"><div class="principle-row__bar" style="width: 5%; --score-percent: 5;" aria-hidden="true"></div><span class="principle-row__value">5,0</span></div></li><li class="principle-row"><div class="principle-row__name">Hanterbar</div><div class="principle-row__bar-container"><div class="principle-row__bar" style="width: 10%; --score-percent: 10;" aria-hidden="true"></div><span class="principle-row__value">10,0</span></div></li><li class="principle-row"><div class="principle-row__name">Begriplig</div><div class="principle-row__bar-container"><div class="principle-row__bar" style="width: 15%; --score-percent: 15;" aria-hidden="true"></div><span class="principle-row__value">15,0</span></div></li><li class="principle-row"><div class="principle-row__name">Robust</div><div class="principle-row__bar-container"><div class="principle-row__bar" style="width: 8%; --score-percent: 8;" aria-hidden="true"></div><span class="principle-row__value">8,0</span></div></li></ul></div></div></div></div></div></div>"
`;
